pb_data/
# Auto-generated schema migrations (we use scripts/setup-pocketbase.mjs as the
# reproducible schema source; these same-second-timestamped files don't replay
# cleanly). To reset locally: delete BOTH pb_data AND pb_migrations, then re-run
# the superuser + setup-pocketbase.mjs steps.
pb_migrations/

# Migration data exported from Supabase (may contain PII) + generated credentials
